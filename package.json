{
	"name": "procella",
	"private": true,
	"workspaces": ["packages/*", "apps/*"],
	"catalog": {
		"@trpc/server": "^11.1.0",
		"drizzle-kit": "^0.31.9",
		"drizzle-orm": "^0.45.1",
		"superjson": "^2.2.2",
		"typescript": "~5.9.3",
		"zod": "^4.3.6"
	},
	"scripts": {
		"prepare": "husky",
		"dev": "bun run dev:deps && trap 'kill 0' EXIT && bun --watch apps/server/src/index.ts & bun run --cwd apps/ui dev & bun run --cwd apps/docs dev --port 4321 & mise exec -- caddy run --config Caddyfile & wait",
		"dev:deps": "docker compose up -d && printf 'Waiting for postgres' && until docker compose exec -T postgres pg_isready -U procella -q 2>/dev/null; do printf '.'; sleep 1; done && echo ' ready'",
		"dev:down": "docker compose down -v",
		"check": "biome check . && bun run typecheck && bun test packages/ apps/ scripts/",
		"typecheck": "tsc --build",
		"types:generate": "sh packages/types/tygo/generate.sh",
		"e2e": "bun test --timeout 120000 --preload ./e2e/setup.ts e2e/",
		"check:all": "bun run check && bun run e2e",
		"db:generate": "drizzle-kit generate --config packages/db/drizzle.config.ts",
		"db:migrate": "drizzle-kit migrate --config packages/db/drizzle.config.ts",
		"bench": "bun run bench/run-benchmark.ts",
		"bench:check": "bun run bench/analyze.ts"
	},
	"devDependencies": {
		"@aws-sdk/client-rds-data": "^3.1018.0",
		"@biomejs/biome": "^2.4.6",
		"@descope/node-sdk": "^2.2.1",
		"@descope/pulumi-descope": "^0.3.4",
		"@pulumi/pulumi": "^3.228.0",
		"@types/aws-lambda": "^8.10.161",
		"@types/bun": "^1.3.10",
		"drizzle-kit": "catalog:",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"sst": "^4.5.11",
		"typescript": "catalog:"
	},
	"lint-staged": {
		"*.{ts,tsx}": ["biome check --write --no-errors-on-unmatched"],
		"*.{json,jsonl,css}": ["biome format --write --no-errors-on-unmatched"]
	}
}

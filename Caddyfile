{
	auto_https off
	admin off
}

:8080 {
	handle /api/* {
		reverse_proxy {$CADDY_GO_UPSTREAM:strata:8080}
	}

	handle /healthz {
		reverse_proxy {$CADDY_GO_UPSTREAM:strata:8080}
	}

	handle /trpc/* {
		reverse_proxy {$CADDY_WEB_UPSTREAM:strata-web:3000}
	}

	handle {
		reverse_proxy {$CADDY_UI_UPSTREAM:strata-ui:80}
	}
}

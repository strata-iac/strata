{
	auto_https off
	admin off
}

:9090 {
	handle /api/* {
		reverse_proxy {$CADDY_GO_UPSTREAM:procella-cluster:9090}
	}

	handle /healthz {
		reverse_proxy {$CADDY_GO_UPSTREAM:procella-cluster:9090}
	}

	handle /trpc/* {
		reverse_proxy {$CADDY_GO_UPSTREAM:procella-cluster:9090}
	}

	handle /docs* {
		reverse_proxy {$CADDY_DOCS_UPSTREAM:localhost:4321}
	}

	@docsDevAssets path_regexp ^\/@(fs|id|vite)\b
	handle @docsDevAssets {
		reverse_proxy {$CADDY_DOCS_UPSTREAM:localhost:4321}
	}

	handle {
		reverse_proxy {$CADDY_UI_UPSTREAM:procella-ui:80}
	}
}

{
	auto_https off
	admin off
}

:9090 {
	handle /api/* {
		reverse_proxy {$CADDY_GO_UPSTREAM:strata-cluster:9090}
	}

	handle /healthz {
		reverse_proxy {$CADDY_GO_UPSTREAM:strata-cluster:9090}
	}

	handle /trpc/* {
		reverse_proxy {$CADDY_GO_UPSTREAM:strata-cluster:9090}
	}

	handle {
		reverse_proxy {$CADDY_UI_UPSTREAM:strata-ui:80}
	}
}

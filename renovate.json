{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "schedule": ["at any time"],
  "prConcurrentLimit": 5,
  "packageRules": [
    {
      "matchPackageNames": ["astro", "@astrojs/starlight"],
      "groupName": "astro + starlight"
    }
  ]  
}

{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": ["../tsconfig.base.json", "../.sst/platform/tsconfig.json"],
	"compilerOptions": {
		"composite": false,
		"incremental": false,
		"noEmit": true,
		"declaration": false,
		"declarationMap": false,
		"sourceMap": false,
		"noUnusedLocals": false,
		"noUnusedParameters": false
	},
	"include": ["**/*.ts", "**/*.json", "../sst-env.d.ts", "../.sst/platform/config.d.ts"],
	"exclude": ["../node_modules"]
}

{
  "componentsVersion": "2.3.1",
  "references": {},
  "styles": {
    "dark": {
      "globals": {
        "fonts": {
          "font1": {
            "family": [
              "Inter",
              "ui-sans-serif",
              "system-ui",
              "-apple-system",
              "BlinkMacSystemFont",
              "Segoe UI",
              "Helvetica Neue",
              "Arial",
              "Noto Sans",
              "sans-serif"
            ],
            "label": "Inter",
            "url": "https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
          }
        },
        "typography": {
          "body1": {
            "font": "var(--descope-fonts-font1-family)",
            "size": "14px",
            "weight": "400"
          },
          "body2": {
            "font": "var(--descope-fonts-font1-family)",
            "size": "12px",
            "weight": "400"
          },
          "subtitle1": {
            "font": "var(--descope-fonts-font1-family)",
            "size": "16px",
            "weight": "500"
          },
          "subtitle2": {
            "font": "var(--descope-fonts-font1-family)",
            "size": "14px",
            "weight": "500"
          },
          "h1": {
            "font": "var(--descope-fonts-font1-family)",
            "size": "36px",
            "weight": "600"
          },
          "h2": {
            "font": "var(--descope-fonts-font1-family)",
            "size": "28px",
            "weight": "600"
          },
          "h3": {
            "font": "var(--descope-fonts-font1-family)",
            "size": "20px",
            "weight": "600"
          }
        }
      },
      "components": {
        "container": {
          "--descope-container-background-color": "#09090bFF"
        },
        "button": {
          "--descope-button-border-radius": "8px",
          "--descope-button-font-family": "var(--descope-fonts-font1-family)",
          "--descope-button-border-width": "1px",
          "--descope-button-border-style": "solid",
          "mode": {
            "primary": {
              "--descope-button-main": "#2563eb",
              "--descope-button-light": "#60a5fa",
              "--descope-button-dark": "#1d4ed8",
              "--descope-button-contrast": "#eff6ff",
              "--descope-button-border-color": "#2563eb"
            },
            "secondary": {
              "--descope-button-main": "#27272a",
              "--descope-button-light": "#3f3f46",
              "--descope-button-dark": "#18181b",
              "--descope-button-contrast": "#f4f4f5",
              "--descope-button-border-color": "#3f3f46"
            }
          }
        },
        "inputWrapper": {
          "--descope-input-wrapper-background-color": "#18181bFF",
          "--descope-input-wrapper-border-radius": "8px",
          "--descope-input-wrapper-font-family": "var(--descope-fonts-font1-family)",
          "--descope-input-wrapper-label-text-color": "#a1a1aaFF",
          "--descope-input-wrapper-placeholder-text-color": "#71717aFF",
          "--descope-input-wrapper-value-text-color": "#f4f4f5FF",
          "--descope-input-wrapper-border-color": "#3f3f46FF",
          "_bordered": {}
        },
        "text": {
          "mode": {
            "primary": {
              "--descope-text-text-color": "#f4f4f5"
            },
            "secondary": {
              "--descope-text-text-color": "#a1a1aaFF"
            },
            "error": {
              "--descope-text-text-color": "#f87171FF"
            }
          }
        },
        "link": {
          "mode": {
            "primary": {
              "--descope-link-text-color": "#60a5faFF"
            }
          }
        },
        "password": {
          "--descope-password-reveal-button-color": "var(--descope-input-wrapper-value-text-color)"
        }
      }
    },
    "light": {
      "globals": {
        "fonts": {

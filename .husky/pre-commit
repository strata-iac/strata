#!/usr/bin/env sh

# Procella pre-commit hook — runs quality gates via bun scripts.
# Checks are scoped to what actually changed to keep commits fast.
# All commands live in package.json — this hook only decides WHICH scripts to run.
# NOTE: husky v9 runs hooks with `sh`, so this must be POSIX-compatible.

set -eu

STAGED=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$STAGED" ]; then
  exit 0
fi

# Detect which areas changed using grep on the staged file list.
# This avoids while-read-in-pipe subshell issues in POSIX sh.
TS_CHANGED=false
UI_CHANGED=false
INFRA_CHANGED=false
DOCS_CHANGED=false

if printf '%s\n' "$STAGED" | grep -qE '^(packages/|apps/server/).*\.ts$'; then
  TS_CHANGED=true
fi
if printf '%s\n' "$STAGED" | grep -qE '^apps/ui/.*\.(ts|tsx)$'; then
  UI_CHANGED=true
fi
if printf '%s\n' "$STAGED" | grep -qE '^(Dockerfile|docker-compose\.yml|Caddyfile|\.github/)'; then
  INFRA_CHANGED=true
fi
if printf '%s\n' "$STAGED" | grep -qE '^(AGENTS\.md|README\.md|apps/docs/)'; then
  DOCS_CHANGED=true
fi

FAIL=0

if [ "$TS_CHANGED" = true ]; then
  echo "▶ bun run check (lint → typecheck → test)"
  if ! bun run check 2>&1; then
    FAIL=1
  fi
fi

if [ "$UI_CHANGED" = true ]; then
  echo "▶ bun run check:ui (UI: lint → typecheck)"
  if ! bun run check:ui 2>&1; then
    FAIL=1
  fi
fi

if [ "$TS_CHANGED" = true ] || [ "$UI_CHANGED" = true ] || [ "$INFRA_CHANGED" = true ]; then
  if [ "$DOCS_CHANGED" = false ]; then
    echo ""
    echo "⚠  Code/infra changed without docs update. Verify these are current:"
    echo "   - AGENTS.md (directory structure, tech stack, quality gates)"
    echo "   - README.md (project structure, tech stack table)"
    echo "   - apps/docs/ (architecture, testing, contributing)"
    echo ""
  fi
fi

if [ "$FAIL" -ne 0 ]; then
  echo ""
  echo "✖ Pre-commit checks failed. Fix issues above before committing."
  exit 1
fi

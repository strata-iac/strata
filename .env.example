# Server
STRATA_LISTEN_ADDR=:9090
STRATA_DATABASE_URL=postgres://strata:strata@localhost:5432/strata?sslmode=disable

# Auth — "dev" (static tokens) or "descope" (Descope access keys)
STRATA_AUTH_MODE=dev
STRATA_DEV_AUTH_TOKEN=devtoken123
STRATA_DEV_USER_LOGIN=dev-user
STRATA_DEV_ORG_LOGIN=dev-org
# STRATA_DEV_USERS='[{"token":"token-user-b","login":"user-b","org":"org-b","role":"admin"}]'
# STRATA_DESCOPE_PROJECT_ID=P2xxxYourProjectId

# Blob storage — "local" (filesystem) or "s3" (S3-compatible)
STRATA_BLOB_BACKEND=local
STRATA_BLOB_LOCAL_PATH=./data/blobs
# STRATA_BLOB_BACKEND=s3
# STRATA_BLOB_S3_BUCKET=strata-checkpoints
# STRATA_BLOB_S3_ENDPOINT=http://localhost:9000
# STRATA_BLOB_S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=minio
# AWS_SECRET_ACCESS_KEY=minio

# Encryption — 64 hex chars (32 bytes). Auto-generated in dev mode.
# STRATA_ENCRYPTION_KEY=

# CORS — comma-separated allowed origins. Unrestricted if unset.
# STRATA_CORS_ORIGINS=https://dashboard.example.com,https://admin.example.com

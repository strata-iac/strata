# Server (override defaults — copy to .env and adjust)
PROCELLA_LISTEN_ADDR=:9090
PROCELLA_DATABASE_URL=postgres://procella:procella@localhost:5432/procella?sslmode=disable

# Auth — "dev" (static tokens) or "descope" (Descope access keys)
PROCELLA_AUTH_MODE=dev
PROCELLA_DEV_AUTH_TOKEN=devtoken123
PROCELLA_DEV_USER_LOGIN=dev-user
PROCELLA_DEV_ORG_LOGIN=dev-org
# PROCELLA_DEV_USERS='[{"token":"token-user-b","login":"user-b","org":"org-b","role":"admin"}]'
# PROCELLA_DESCOPE_PROJECT_ID=P2xxxYourProjectId

# Blob storage — "local" (filesystem) or "s3" (S3-compatible)
PROCELLA_BLOB_BACKEND=local
PROCELLA_BLOB_LOCAL_PATH=./data/blobs
# PROCELLA_BLOB_BACKEND=s3
# PROCELLA_BLOB_S3_BUCKET=procella-checkpoints
# PROCELLA_BLOB_S3_ENDPOINT=http://localhost:9000
# PROCELLA_BLOB_S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=minio          # MinIO credentials for local S3 (docker-compose)
# AWS_SECRET_ACCESS_KEY=minio      # Keep in .env only — NOT in mise.toml (breaks CI OIDC)

# Encryption — 64 hex chars (32 bytes). Auto-generated in dev mode.
# PROCELLA_ENCRYPTION_KEY=

# CORS — comma-separated allowed origins. Unrestricted if unset.
# PROCELLA_CORS_ORIGINS=https://app.procella.sh,https://procella.sh

# UI build-time variables (Vite — only used during `bun run build` for apps/ui)
# VITE_API_URL — absolute API origin. Empty in dev (Vite proxy) and preview (same origin).
# VITE_API_URL=https://api.procella.sh
# VITE_APP_URL — absolute dashboard origin. Used by the landing page for cross-domain links.
# VITE_APP_URL=https://app.procella.sh

---
/**
 * SiteTitle override — matches ProcellaLogo from apps/ui:
 *   Storm Petrel SVG icon in Lightning + "Procella" wordmark in Mist
 */
import type { Props } from '@astrojs/starlight/props';

const { siteTitle } = Astro.props as Props;
---

<a href="/" class="site-title">
  <!-- Storm Petrel icon — same SVG geometry as ProcellaLogo.tsx -->
  <svg
    viewBox="0 0 24 24"
    fill="none"
    width="20"
    height="20"
    aria-hidden="true"
    style="color: #00D4FF; flex-shrink: 0;"
  >
    <path d="M13 11.5 Q8 7.5 3 4.5 Q7 8 13 11.5Z" fill="currentColor"/>
    <path d="M13 12.5 Q8 16.5 3 19.5 Q7 16 13 12.5Z" fill="currentColor"/>
    <ellipse cx="15" cy="12" rx="4.5" ry="1.8" fill="currentColor"/>
    <circle cx="19.5" cy="11.2" r="1.5" fill="currentColor"/>
    <path d="M10.5 11.5 L7 9.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
    <path d="M10.5 12.5 L7 14.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
    <circle cx="20.2" cy="10.8" r="0.45" fill="#FFB800"/>
    <ellipse cx="11.5" cy="12.3" rx="1" ry="0.55" fill="white" opacity="0.85"/>
  </svg>
  <span>{siteTitle}</span>
</a>

<style>
  .site-title {
    display: flex;
    align-items: center;
    gap: 0.625rem;        /* gap-2.5 */
    text-decoration: none;
    white-space: nowrap;
    font-size: 0.9375rem; /* 15px — matches ProcellaLogo size="sm" */
    font-weight: 700;
    letter-spacing: -0.01em;
    color: #E2E8F0;       /* Mist */
  }

  .site-title:hover {
    color: #ffffff;
  }
</style>

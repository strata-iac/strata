{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"types": ["vite/client", "bun"],
		"jsx": "react-jsx",
		"useDefineForClassFields": true,
		"noEmit": true,
		"declaration": false,
		"declarationMap": false,
		"sourceMap": false,
		"composite": false,
		"incremental": false
	},
	"include": ["src"]
}
